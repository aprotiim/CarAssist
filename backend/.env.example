# Database
DATABASE_URL=postgresql://user:password@localhost:5432/autosage

# Redis
REDIS_URL=redis://localhost:6379

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# App settings
DEBUG=true
APP_VERSION=0.1.0
