# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Exa web search (https://exa.ai)
EXA_API_KEY=your-exa-key-here

# Pinecone vector DB (https://pinecone.io)
PINECONE_API_KEY=your-pinecone-key-here
PINECONE_INDEX_NAME=cargenuity-rag

# AWS — S3 user storage
# On EC2: attach an IAM role with S3 access — no keys needed
# Locally: set these to your IAM user credentials for development
AWS_ACCESS_KEY_ID=your-aws-access-key-id        # not needed on EC2
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key # not needed on EC2
AWS_REGION=us-east-2
S3_USERS_BUCKET=cargenuity-bucket

# Redis
REDIS_URL=redis://localhost:6379

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# App settings
DEBUG=true
APP_VERSION=0.1.0
